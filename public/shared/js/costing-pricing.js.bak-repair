  const { data, error } = await costingFrom(
    "v_costing_policy_manager_selling_policy_history",
  )
    .select("*")
    .eq("sku_id", row.sku_id)
    .order("effective_from", { ascending: false })
    .order("policy_id", { ascending: false })
    .limit(100);

  if (error) throw error;
