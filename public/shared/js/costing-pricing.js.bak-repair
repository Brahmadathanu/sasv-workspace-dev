      ["Product", text(row.product_name || row.product_id)],
      ["SKU", text(row.sku_column_label || row.sku_display_name || row.sku_id)],
      ["MRP IK / OK", `${formatMoney(row.mrp_ik)} / ${formatMoney(row.mrp_ok)}`],
