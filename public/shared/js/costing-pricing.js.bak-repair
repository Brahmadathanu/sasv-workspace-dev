      ? MANUAL_RATE_CLOSE_RETURN_FOCUS
      : drawerClose;

  MANUAL_RATE_CLOSE_ROW = null;
  MANUAL_RATE_CLOSE_RETURN_FOCUS = null;

  if (returnTarget && typeof returnTarget.focus === "function") {
