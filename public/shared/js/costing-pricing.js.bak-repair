function manualProvisionSearchBlob(row) {
  return [
    row.provision_key,
    row.provision_label,
    row.provision_type,
    row.provision_type_label,
    row.allocation_pool,
    row.allocation_pool_label,
    row.source_reference,
    row.remarks,
    row.provision_status,
    row.provision_note,
    row.provision_amount,
  ]
    .filter(Boolean)
    .join(" ")
    .toLowerCase();
}

function applyManualProvisionFilters() {
  const periodStart = manualProvisionFilters.periodStart;
  const allocationPool = manualProvisionFilters.allocationPool || "all";
  const status = manualProvisionFilters.status || "active";
  const search = String(manualProvisionFilters.search || "").trim().toLowerCase();

  filteredManualProvisionRows = manualProvisionRows.filter((row) => {
    if (periodStart && normalizeMonthStart(row.period_start) !== periodStart) return false;
    if (allocationPool !== "all" && String(row.allocation_pool || "") !== allocationPool) return false;
    if (status === "active" && !row.is_active) return false;
    if (status === "inactive" && row.is_active) return false;
    if (search && !manualProvisionSearchBlob(row).includes(search)) return false;
    return true;
  });

  ALL_ROWS = manualProvisionRows;
  VIEW = filteredManualProvisionRows;
}

function renderManualProvisionKpis() {
  const totalRows = manualProvisionRows.length;
  const activeRows = manualProvisionRows.filter((row) => !!row.is_active).length;
  const inactiveRows = manualProvisionRows.filter((row) => !row.is_active).length;
  const manualAmount = filteredManualProvisionRows.reduce(
    (sum, row) => sum + (row.is_active ? toNumber(row.provision_amount) : 0),
    0,
  );
  if (mpKpiTotalRows) mpKpiTotalRows.textContent = formatNumber(totalRows);
  if (mpKpiActiveRows) mpKpiActiveRows.textContent = formatNumber(activeRows);
  if (mpKpiInactiveRows) mpKpiInactiveRows.textContent = formatNumber(inactiveRows);
  if (mpKpiManualAmount) mpKpiManualAmount.textContent = formatMoney(manualAmount);
  if (mpKpiVisibleRows) mpKpiVisibleRows.textContent = formatNumber(filteredManualProvisionRows.length);
}

function renderManualProvisionRegisterTable() {
  if (!mpProvisionTableBody) return;
  if (!filteredManualProvisionRows.length) {
    mpProvisionTableBody.innerHTML = `<tr><td colspan="9" class="cp-muted-text">No manual provisions found for the selected filters.</td></tr>`;
  } else {
    mpProvisionTableBody.innerHTML = filteredManualProvisionRows
      .map(
        (row) => `
      <tr class="clickable" data-manual-provision-id="${escapeHtml(row.provision_id)}">
        <td>${formatDate(row.period_start)}</td>
        <td><strong>${text(row.allocation_pool_label || row.allocation_pool || "--")}</strong><div class="cp-muted-text">${text(row.allocation_pool || "--")}</div></td>
        <td><strong>${text(row.provision_type_label || row.provision_type || "--")}</strong><div class="cp-muted-text">${text(row.provision_type || "--")}</div></td>
        <td title="${escapeHtml(row.provision_note || "")}"><strong>${text(row.provision_label || "--")}</strong><div class="cp-muted-text">${text(row.provision_key || "--")}</div></td>
        <td class="c-right">${formatMoney(row.provision_amount)}</td>
        <td>${text(row.source_reference || "--")}</td>
        <td>${manualProvisionStatusText(row)}</td>
        <td>${formatDateTime(row.updated_at || row.created_at)}</td>
        <td class="c-center">
          <div style="display:flex;gap:6px;justify-content:center">
            <button type="button" class="icon-btn" data-manual-provision-edit-id="${escapeHtml(row.provision_id)}" title="Edit Manual Provision">Edit</button>
            ${row.is_active ? `<button type="button" class="icon-btn cp-danger-icon-btn" data-manual-provision-deactivate-id="${escapeHtml(row.provision_id)}" title="Deactivate Manual Provision">×</button>` : ""}
          </div>
        </td>
      </tr>`,
      )
      .join("");
  }
  if (mpProvisionRowCount) {
    mpProvisionRowCount.textContent = `${filteredManualProvisionRows.length.toLocaleString("en-IN")} row${filteredManualProvisionRows.length === 1 ? "" : "s"}`;
  }
  mpProvisionTableBody.querySelectorAll("tr[data-manual-provision-id]").forEach((tr) => {
    tr.addEventListener("click", () => openManualProvisionModal(Number(tr.dataset.manualProvisionId)));
  });
  mpProvisionTableBody.querySelectorAll("[data-manual-provision-edit-id]").forEach((btn) => {
    btn.addEventListener("click", (event) => {
      event.stopPropagation();
      openManualProvisionModal(Number(btn.dataset.manualProvisionEditId));
    });
  });
  mpProvisionTableBody.querySelectorAll("[data-manual-provision-deactivate-id]").forEach((btn) => {
    btn.addEventListener("click", (event) => {
      event.stopPropagation();
      openManualProvisionDeactivateModal(Number(btn.dataset.manualProvisionDeactivateId));
    });
  });
}

function renderManualProvisionPoolImpactTable() {
  if (!mpPoolImpactTableBody) return;

  if (!manualProvisionPoolImpactRows.length) {
    mpPoolImpactTableBody.innerHTML = `<tr><td colspan="8" class="cp-muted-text">No pool impact rows found for the selected filters.</td></tr>`;
  } else {
