async function fetchAllPrintableLinesForPeriod(periodStart) {
  const pageSize = 1000;
  let from = 0;
  const rows = [];

  while (true) {
    const to = from + pageSize - 1;
    const { data, error } = await costingFrom(
      "v_costing_pricing_printable_cost_sheet_lines",
    )
      .select("*")
      .eq("period_start", periodStart)
      .order("product_name", { ascending: true })
      .order("product_id", { ascending: true })
      .order("pack_size", { ascending: true })
      .order("section_code", { ascending: true })
      .order("line_order", { ascending: true })
      .range(from, to);

    if (error) throw error;
    const pageRows = data || [];
    rows.push(...pageRows);
    if (pageRows.length < pageSize) break;
    from += pageSize;
  }

  return rows;
}

async function fetchAllRows(queryBuilderFactory, pageSize = 1000) {
  let from = 0;
  const all = [];

  while (true) {
    const to = from + pageSize - 1;
    const query = queryBuilderFactory().range(from, to);
    const { data, error } = await query;
    if (error) throw error;

    const rows = data || [];
    all.push(...rows);

    if (rows.length < pageSize) break;
    from += pageSize;
  }

  return all;
}

function normalizeMonthStart(value) {
  if (!value) return "";
  if (value instanceof Date) {
    const year = value.getFullYear();
    const month = String(value.getMonth() + 1).padStart(2, "0");
    return `${year}-${month}-01`;
  }
  const raw = String(value).trim();
  if (!raw) return "";
  if (/^\d{4}-\d{2}$/.test(raw)) return `${raw}-01`;
  const match = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if (match) return `${match[1]}-${match[2]}-01`;
  const parsed = new Date(raw);
  if (Number.isNaN(parsed.getTime())) return "";
  const year = parsed.getFullYear();
  const month = String(parsed.getMonth() + 1).padStart(2, "0");
  return `${year}-${month}-01`;
}

function monthInputValue(value) {
  const normalized = normalizeMonthStart(value);
  return normalized ? normalized.slice(0, 7) : "";
}

function setVisible(el, visible, displayValue = "") {
  if (!el) return;
  el.classList.toggle("hidden", !visible);
  el.style.display = visible ? displayValue : "none";
}

function isManualProvisionsLens() {
  return CURRENT_LENS === "manual-provisions";
}

function syncManualProvisionLayout() {
  const isManual = isManualProvisionsLens();

  setVisible(manualProvisionsPanel, isManual, "block");
  setVisible(kpiStripWrap, !isManual, "");
  setVisible(globalSearchCard, !isManual, "flex");
  setVisible(genericTableMetaRow, !isManual, "flex");

  if (tableWrap) {
    tableWrap.classList.toggle("hidden", isManual);
    if (isManual) {
      tableWrap.classList.remove("tw-visible");
      tableWrap.style.display = "none";
    } else {
      tableWrap.style.display = "";
    }
  }

  if (isManual) {
    workbenchSummary?.classList.remove("is-visible");
    if (workbenchSummary) workbenchSummary.innerHTML = "";
    if (statusArea) {
      statusArea.style.display = "none";
      statusArea.innerHTML = "";
    }
  }
}

function manualProvisionStatusText(row) {
  const status = row?.provision_status || (row?.is_active ? "ACTIVE" : "INACTIVE");
  return compactStatusText(status);
}

function populateManualProvisionPoolSelect(selectEl, includeAll = false) {
  if (!selectEl) return;
  const options = [];
  if (includeAll) options.push(`<option value="all">All Pools</option>`);
  options.push(
    ...manualProvisionPoolOptions.map((row) => {
      const value = row.allocation_pool || "";
      const label = row.allocation_pool_label || value || "--";
      return `<option value="${escapeHtml(value)}">${escapeHtml(label)}</option>`;
    }),
  );
  selectEl.innerHTML = options.join("");
}

function populateManualProvisionTypeSelect(selectEl) {
  if (!selectEl) return;
  selectEl.innerHTML = manualProvisionTypeOptions
    .map((row) => {
      const value = row.provision_type || "";
      const label = row.provision_type_label || value || "--";
      return `<option value="${escapeHtml(value)}">${escapeHtml(label)}</option>`;
    })
    .join("");
}

